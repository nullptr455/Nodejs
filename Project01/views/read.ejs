<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheet/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="h-full w-full bg-zinc-900 text-white p-10">
        <div class="text-2xl text-zinc-500 mb-4">
            <a href="/">back to Home</a>
        </div>
      <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>
      <div class="users flex gap-3 flex-wrap">
        <% if(users.length > 0) { %>
        <% users.forEach((user) => { %>
            <div class="user w-72 p-4 bg-zinc-800 rounded-lg mb-3">
          <div class="w-full h-52 rounded-lg bg-zinc-700 overflow-hidden">
            <img
             src="<%= user.image %>"
             alt="<%= user.name %>"
             class="w-full h-52 rounded-lg object-cover"
            />
          </div>
          <h3 class="text-xl tracking-tighter mt-3"><%=user.name %>
          </h3>
          <h5 class="text-zinc-500"><%=user.email %></h5>
          <div class="flex gap-3 mt-7">
            <a class="text-zinc-200" href="/">Edit User</a>
            <a class="text-red-500" href="/delete/<%= user._id %>">Delete User</a>
          </div>
          
        </div>
            
            
        <% }) %>
        <% } else { %>
            
            <h3>Not user yet</h3>
            <%} %>
       
          
       
        </div>
      </div>
    </div>
  </body>
</html>
