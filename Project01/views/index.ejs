<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheet/style.css" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="h-full w-full bg-zinc-900 text-white p-10">
        <div class="text-2xl text-zinc-500 mb-4">
            <a href="/read">Go to Users</a>
        </div>
      <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>
      <form action="/create" method="post">
        <input
          class="px-5 py-3 border-2 border-zinc-500 outline-none rounded-lg bg-transparent"
          type="text"
          name="name"
          placeholder="Name"
        />

        <input
          class="px-5 py-3 border-2 border-zinc-500 outline-none rounded-lg bg-transparent"
          type="email"
          name="email"
          placeholder="Email"
        />

        <input
          class="px-5 py-3 border-2 border-zinc-500 outline-none rounded-lg bg-transparent"
          type="text"
          name="image"
          placeholder="Image URL"
        />
        <input
          class="px-5 py-3 bg-blue-500 rounded-md ml-5"
          type="submit"
          value="create user"
        />
      </form>
    </div>
  </body>
</html>
