<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class ="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
           <a class="inline-block px-3 py-2 text-sm bg-red-500 rounded-md" href="/logout">logout</a>
        </div>
        
        <h5 class="mb-5">Edit your post</h5>

        <form  method="post" action="/update/<%= post._id %>">
            <div>
                <textarea class="block mb-3 p-3 w-1/3 outline-none  resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content" placeholder="What's on your mind?"><%= post.content %></textarea>
                <input class="block px-3 py-2 w-40 text-sm bg-yellow-500  text-black rounded-md" type="submit" value = "Update post">
            </div>
        </form>
        
    </div>
</body>
</html>