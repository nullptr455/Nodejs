<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class ="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
           <a class="inline-block px-3 py-2 text-sm bg-red-500 rounded-md" href="/logout">logout</a>
        </div>
        <h3 class="text-3xl"> <span class="font-light">Hello </span> , <%= user.name %></h3>
        <h5 class="mb-5">you can create a post</h5>

        <form action="/post" method="post">
            <div>
                <textarea class="block mb-3 p-3 w-1/3 outline-none  resize-none bg-transparent border-2 border-zinc-800 rounded-md" name="content" placeholder="What's on your mind?"></textarea>
                <input class="block px-3 py-2 w-40 text-sm bg-blue-500 rounded-md" type="submit" value = "Create your post">
            </div>
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinc-400">Your Posts</h3>
            <div class="postcontent mt-5">
               <% user.posts.reverse().forEach(function(post) { %>

             <div class="post w-1/3 p-4 mb-4 rounded-lg border-zinc-900 border-[1px] bg-zinc-800">
                  <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
                   <p class="text-sm tracking-tight"><%= post.content %></p>

                 <div class="btns flex gap-4 mt-5">
                    <a class="text-blue-500" href="">like</a>
                    <a class="text-zinc-400" href="">edit</a>
             </div>
            </div>

           <% }) %>
            </div>
        </div>

        
    </div>
</body>
</html>