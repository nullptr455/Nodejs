<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
         <form action="/login" method="post">
            
            <input class="px-3 py-2 border-2 rounded-md bg-transparent border-zinc-800" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 border-2 rounded-md bg-transparent border-zinc-800" type="password" placeholder="password" name="password">
            <input class ="px-3 py-2 bg-blue-500 ml-3 rounded-lg" type="submit" value ="Login">
         </form>
    </div>
</body>
</html>